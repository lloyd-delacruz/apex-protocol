// Apex Protocol — Prisma Schema
// Based on DATABASE_SCHEMA.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Roles ────────────────────────────────────────────────────────────────────

model Role {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  roleId       String    @map("role_id")
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash")
  firstName    String?   @map("first_name") @db.VarChar(100)
  lastName     String?   @map("last_name") @db.VarChar(100)
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  role                   Role                    @relation(fields: [roleId], references: [id])
  refreshTokens          RefreshToken[]
  bodyMetrics            BodyMetric[]
  trainingLogs           TrainingLog[]
  userProgramAssignments UserProgramAssignment[]

  @@index([roleId])
  @@map("users")
}

// ─── Refresh Tokens ───────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── Programs ─────────────────────────────────────────────────────────────────

model Program {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?
  totalWeeks  Int       @map("total_weeks")
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  programMonths          ProgramMonth[]
  userProgramAssignments UserProgramAssignment[]
  trainingLogs           TrainingLog[]

  @@map("programs")
}

// ─── Program Months ───────────────────────────────────────────────────────────

model ProgramMonth {
  id          String   @id @default(uuid())
  programId   String   @map("program_id")
  monthNumber Int      @map("month_number")
  name        String   @db.VarChar(255)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  program      Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  programWeeks ProgramWeek[]

  @@unique([programId, monthNumber])
  @@map("program_months")
}

// ─── Program Weeks ────────────────────────────────────────────────────────────

model ProgramWeek {
  id                 String   @id @default(uuid())
  programMonthId     String   @map("program_month_id")
  weekNumber         Int      @map("week_number")
  absoluteWeekNumber Int      @map("absolute_week_number")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  programMonth ProgramMonth @relation(fields: [programMonthId], references: [id], onDelete: Cascade)
  workoutDays  WorkoutDay[]
  trainingLogs TrainingLog[]

  @@unique([programMonthId, weekNumber])
  @@map("program_weeks")
}

// ─── Workout Days ─────────────────────────────────────────────────────────────

model WorkoutDay {
  id            String   @id @default(uuid())
  programWeekId String   @map("program_week_id")
  dayCode       String   @map("day_code") @db.VarChar(20)
  phase         String   @db.VarChar(50)
  workoutType   String   @map("workout_type") @db.VarChar(100)
  sortOrder     Int      @map("sort_order")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  programWeek           ProgramWeek            @relation(fields: [programWeekId], references: [id], onDelete: Cascade)
  exercisePrescriptions ExercisePrescription[]
  trainingLogs          TrainingLog[]

  @@index([programWeekId])
  @@index([sortOrder])
  @@map("workout_days")
}

// ─── Exercises ────────────────────────────────────────────────────────────────

model Exercise {
  id          String    @id @default(uuid())
  name        String    @unique @db.VarChar(255)
  category    String?   @db.VarChar(100)
  muscleGroup String?   @map("muscle_group") @db.VarChar(100)
  equipment   String?   @db.VarChar(100)
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  exercisePrescriptions     ExercisePrescription[]
  substitutionsAsOriginal   ExerciseSubstitution[] @relation("OriginalExercise")
  substitutionsAsSubstitute ExerciseSubstitution[] @relation("SubstituteExercise")
  trainingLogs              TrainingLog[]

  @@map("exercises")
}

// ─── Exercise Substitutions ───────────────────────────────────────────────────

model ExerciseSubstitution {
  id                   String   @id @default(uuid())
  exerciseId           String   @map("exercise_id")
  substituteExerciseId String   @map("substitute_exercise_id")
  priorityRank         Int      @default(1) @map("priority_rank")
  notes                String?
  createdAt            DateTime @default(now()) @map("created_at")

  exercise           Exercise @relation("OriginalExercise", fields: [exerciseId], references: [id])
  substituteExercise Exercise @relation("SubstituteExercise", fields: [substituteExerciseId], references: [id])

  @@unique([exerciseId, substituteExerciseId])
  @@map("exercise_substitutions")
}

// ─── Exercise Prescriptions ───────────────────────────────────────────────────

model ExercisePrescription {
  id             String   @id @default(uuid())
  workoutDayId   String   @map("workout_day_id")
  exerciseId     String   @map("exercise_id")
  targetRepRange String?  @map("target_rep_range") @db.VarChar(50)
  incrementValue Decimal  @default(0) @map("increment_value") @db.Decimal(6, 2)
  incrementUnit  String   @default("lb") @map("increment_unit") @db.VarChar(20)
  notes          String?
  sortOrder      Int      @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  workoutDay   WorkoutDay    @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exercise     Exercise      @relation(fields: [exerciseId], references: [id])
  trainingLogs TrainingLog[]

  @@index([workoutDayId])
  @@index([exerciseId])
  @@index([sortOrder])
  @@map("exercise_prescriptions")
}

// ─── User Program Assignments ─────────────────────────────────────────────────

model UserProgramAssignment {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  programId  String    @map("program_id")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id])

  @@index([userId])
  @@index([programId])
  @@map("user_program_assignments")
}

// ─── Training Logs ────────────────────────────────────────────────────────────

model TrainingLog {
  id                     String    @id @default(uuid())
  userId                 String    @map("user_id")
  programId              String?   @map("program_id")
  programWeekId          String?   @map("program_week_id")
  workoutDayId           String?   @map("workout_day_id")
  exercisePrescriptionId String?   @map("exercise_prescription_id")
  exerciseId             String    @map("exercise_id")
  sessionDate            DateTime  @map("session_date") @db.Date
  weight                 Decimal?  @db.Decimal(8, 2)
  weightUnit             String    @default("lb") @map("weight_unit") @db.VarChar(20)
  set1Reps               Int?      @map("set_1_reps")
  set2Reps               Int?      @map("set_2_reps")
  set3Reps               Int?      @map("set_3_reps")
  set4Reps               Int?      @map("set_4_reps")
  rir                    Int?
  totalReps              Int?      @map("total_reps")
  lowerRep               Int?      @map("lower_rep")
  upperRep               Int?      @map("upper_rep")
  readyToIncrease        Boolean?  @map("ready_to_increase")
  nextWeight             Decimal?  @map("next_weight") @db.Decimal(8, 2)
  status                 String?   @db.VarChar(20)
  notes                  String?
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  program              Program?              @relation(fields: [programId], references: [id])
  programWeek          ProgramWeek?          @relation(fields: [programWeekId], references: [id])
  workoutDay           WorkoutDay?           @relation(fields: [workoutDayId], references: [id])
  exercisePrescription ExercisePrescription? @relation(fields: [exercisePrescriptionId], references: [id])
  exercise             Exercise              @relation(fields: [exerciseId], references: [id])

  @@index([userId])
  @@index([sessionDate])
  @@index([exerciseId])
  @@index([status])
  @@index([userId, sessionDate])
  @@index([userId, exerciseId, sessionDate])
  @@map("training_logs")
}

// ─── Body Metrics ─────────────────────────────────────────────────────────────

model BodyMetric {
  id                       String   @id @default(uuid())
  userId                   String   @map("user_id")
  entryDate                DateTime @map("entry_date") @db.Date
  bodyWeight               Decimal? @map("body_weight") @db.Decimal(6, 2)
  bodyWeightUnit           String   @default("kg") @map("body_weight_unit") @db.VarChar(20)
  calories                 Int?
  proteinGrams             Int?     @map("protein_grams")
  sleepHours               Decimal? @map("sleep_hours") @db.Decimal(4, 2)
  hungerScore              Int?     @map("hunger_score")
  bingeUrgeScore           Int?     @map("binge_urge_score")
  moodScore                Int?     @map("mood_score")
  trainingPerformanceScore Int?     @map("training_performance_score")
  notes                    String?
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate])
  @@index([userId])
  @@index([entryDate])
  @@map("body_metrics")
}
