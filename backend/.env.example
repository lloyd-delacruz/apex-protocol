# Apex Protocol Backend — Environment Variables
# Copy to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:4000

# ─── Database (Prisma) ────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/apex_protocol"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production
JWT_SECRET=apex-protocol-dev-secret-change-in-production
